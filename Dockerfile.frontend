FROM node:20-bookworm-slim

WORKDIR /app/dashboard

COPY dashboard/package*.json ./
RUN npm ci

COPY dashboard/ ./

# Build without baking in the backend URL.
# The frontend proxies API calls through Next.js rewrites → BACKEND_URL at runtime.
RUN npm run build

EXPOSE 3000
CMD sh -c "npm run start -- -H 0.0.0.0 -p ${PORT:-3000}"

# Required API Keys
OPENAI_API_KEY=your_openai_api_key
DEEPGRAM_API_KEY=your_deepgram_api_key
CARTESIA_API_KEY=your_cartesia_api_key

# Daily.co Configuration
# 1. Create a Daily room and copy the URL
DAILY_ROOM_URL=https://your-domain.daily.co/your-room
# 2. Generate a token for the room with dial-out permissions
DAILY_TOKEN=your_daily_token

# Target Phone Number (The number the AI will call)
# Must be in E.164 format, e.g., +1234567890
TARGET_PHONE_NUMBER=+1234567890

# Twilio (You will need these configured on Twilio & Daily side, see instructions)
# The dialout via daily will route to Twilio automatically if you set up the Daily SIP URI with Twilio credentials.
# In pipecat, dialout handles the connection seamlessly through the daily transport.

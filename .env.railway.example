# =============================================================================
# Railway Environment Variables Template
# =============================================================================
# Copy these variable names into your Railway service's "Variables" tab.
# Do NOT commit actual secrets to git.
#
# HOW TO USE:
#   1. Go to railway.app → your project
#   2. Click the "backend" service → Variables tab
#   3. Add each variable below with your real values
# =============================================================================

# ---------------------------------------------------------------------------
# LiveKit (required for voice interview sessions)
# Get these from: https://cloud.livekit.io
# ---------------------------------------------------------------------------
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ---------------------------------------------------------------------------
# LLM Provider (set one — used by the interview agent)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key
# OPENAI_API_KEY=your_openai_api_key

# ---------------------------------------------------------------------------
# TTS Provider
# ---------------------------------------------------------------------------
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# ---------------------------------------------------------------------------
# STT Provider
# ---------------------------------------------------------------------------
DEEPGRAM_API_KEY=your_deepgram_api_key

# ---------------------------------------------------------------------------
# Database (set automatically by Railway volume mount — do not change)
# ---------------------------------------------------------------------------
INTERVIEW_DB_PATH=/data/interview.db

# ---------------------------------------------------------------------------
# CORS (set this to your Railway frontend public URL after first deploy)
# Example: https://dashboard-production-xxxx.up.railway.app
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=*

# ---------------------------------------------------------------------------
# Frontend only — set this to your Railway BACKEND public URL
# Example: https://backend-production-xxxx.up.railway.app
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=https://your-backend.up.railway.app
